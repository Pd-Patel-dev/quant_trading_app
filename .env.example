ALPACA_API_KEY=your_paper_api_key
ALPACA_SECRET_KEY=your_paper_secret_key

# Use Alpaca paper account cash for strategy allocation limits (recommended).
# Set to "local" only for offline/testing without Alpaca.
PAPER_CAPITAL_SOURCE=alpaca

# Fallback local virtual pool when PAPER_CAPITAL_SOURCE=local
# LOCAL_PAPER_CAPITAL_POOL=100000
